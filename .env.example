# qed'bop platform — required environment variables
# Copy to .env.local for development. Never commit .env.local.

# ---------- Database ----------
# Postgres connection string. On Railway, this is provided automatically when
# you attach a Postgres plugin (env name: DATABASE_URL).
DATABASE_URL="postgresql://user:password@localhost:5432/qedbop"

# ---------- Auth.js ----------
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# In production set this to the canonical https URL.
AUTH_URL="http://localhost:3000"

# Google OAuth (optional — Credentials provider works without these).
# Create at https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ---------- Anthropic ----------
ANTHROPIC_API_KEY=""
# Override only if you need to pin a specific model. Defaults to a recent
# Sonnet in lib/claude.ts.
# ANTHROPIC_MODEL="claude-sonnet-4-5"

# ---------- Admin bootstrap ----------
# Comma-separated email addresses that get the ADMIN role on first sign-in.
# Used by lib/auth.ts to promote John + Dante automatically.
ADMIN_EMAILS=""

# ---------- Public URL ----------
# Used to build absolute URLs (QR codes, shareable links). No trailing slash.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
