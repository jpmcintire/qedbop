// qed'bop teacher platform — data model
//
// See ARCHITECTURE.md for the full spec. Conventions:
//   - Auth.js v5 NextAuth tables (User/Account/Session/VerificationToken) are
//     present so we can mix Credentials (email/password) and Google OAuth.
//   - Teacher profile fields live on User directly (one user = one teacher).
//   - The two-field music-notes split (music_text_teacher_only vs.
//     music_text_themes) is enforced at the API layer; the schema simply
//     stores both columns.
//   - AssignmentPage.depthToggles is JSON: { extendedBio, historicalContext,
//     genreSociology, crossCurricular, technicalPoetry, creativeResponse,
//     scaffoldedListening }
//   - generatedCurriculum is JSON shaped by lib/schemas.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Auth.js tables ----------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Teacher (= User) ----------

enum Role {
  TEACHER
  ADMIN
}

enum CourseType {
  REGULAR
  HONORS
  AP
  COLLEGE
}

enum SubscriptionStatus {
  FREE
  TRIAL
  ACTIVE
  LAPSED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  role Role @default(TEACHER)

  school       String?
  state        String?
  gradeLevels  String[]   @default([])
  courseType   CourseType?
  classNames   String[]   @default([])

  subscriptionStatus SubscriptionStatus @default(FREE)
  subscriptionExpiry DateTime?

  accounts  Account[]
  sessions  Session[]
  pages     AssignmentPage[]
  notes     TeacherNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------- Work & Version ----------

enum WorkType {
  POEM
  PASSAGE
  SPEECH
  DRAMATIC
}

enum CopyrightStatus {
  PUBLIC_DOMAIN
  LICENSED
  UNKNOWN
}

enum YouTubeStatus {
  PUBLIC
  UNLISTED
}

model Work {
  id              String          @id @default(cuid())
  title           String
  author          String
  fullText        String          @db.Text
  type            WorkType
  sourceWork      String?
  publicationYear Int?
  copyrightStatus CopyrightStatus @default(PUBLIC_DOMAIN)
  gradeBands      String[]        @default([])
  themes          String[]        @default([])
  notes           String?         @db.Text

  versions Version[]
  notesByTeachers TeacherNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Version {
  id               String        @id @default(cuid())
  workId           String
  label            String
  youtubeId        String
  youtubeStatus    YouTubeStatus @default(UNLISTED)
  durationSeconds  Int?
  musicDescription String?       @db.Text
  chorusPhrases    String?       @db.Text
  vocalCharacter   String?
  isRecommended    Boolean       @default(false)

  // CRITICAL: never feed musicTextTeacherOnly to Claude for student-facing
  // content generation. lib/claude.ts strips this field at the boundary.
  musicTextTeacherOnly String @default("") @db.Text
  musicTextThemes      String @default("") @db.Text

  // Internal pedagogical ratings (1-5), not shown to teachers
  musicTextDepth      Int?
  comparativeValue    Int?
  emotionalImpact     Int?
  accessibility       Int?
  discussionPotential Int?

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------- AssignmentPage ----------

enum DeliveryModality {
  IN_CLASS
  HOMEWORK
  MIXED
}

enum AssignmentType {
  COMPARE_VERSIONS
  SINGLE_ANALYSIS
  MULTIPLE_POEMS
  THEMATIC
  NOVEL_POEM
  BE_PRODUCER
  WHATS_MISSING
}

enum AssignmentStatus {
  ACTIVE
  EXPIRED
  ARCHIVED
}

model AssignmentPage {
  id                  String           @id @default(cuid())
  teacherId           String
  versionIds          String[]
  deliveryModality    DeliveryModality
  assignmentType      AssignmentType
  depthToggles        Json
  generatedCurriculum Json
  teacherCustomizations Json?
  urlSlug             String           @unique
  teacherDisplayName  String?
  classDisplayName    String?
  expiresAt           DateTime?
  publishedAt         DateTime         @default(now())
  status              AssignmentStatus @default(ACTIVE)
  followUpSentAt      DateTime?

  teacher User @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teacherId])
  @@index([status, publishedAt])
}

// ---------- TeacherNote ----------

model TeacherNote {
  id        String   @id @default(cuid())
  workId    String
  teacherId String
  body      String   @db.Text
  flagged   Boolean  @default(false)

  work    Work @relation(fields: [workId], references: [id], onDelete: Cascade)
  teacher User @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}
