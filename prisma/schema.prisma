// Scoped Prisma usage: a single VideoAnnotation table that stores
// per-video metadata (overrides for the static defaults in lib/poems.ts).
// The Postgres database is attached to Railway from the original platform
// attempt; this brings it into use without re-introducing auth, admin
// pages, accounts, or any of the surface area that made deploys painful.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model VideoAnnotation {
  youtubeId       String   @id
  // Optional override of the static label in lib/poems.ts (e.g. "Folk
  // acoustic — Solo guitar"). When null, falls back to the static label.
  label           String?
  // Objective metadata, safe to share with Claude for any output.
  durationSeconds Int?
  genre           String?
  vocalCharacter  String?
  artist          String?
  recordingYear   Int?
  // Interpretive themes — no timestamps, no specific moments. Used by
  // BOTH student-facing generators (questions) and teacher-facing ones.
  themes          String?  @db.Text
  // Teacher-only annotations — may include timestamps. Used ONLY by
  // teacher-edition + teacher-chat generators. The product's moat
  // depends on this never leaking to student-facing output.
  teacherNotes    String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Per-poet curated facts. Keyed by a slug derived from the author name
// in lib/poems.ts (see slugifyAuthor). The AI generates the bulk of the
// poet bio + historical context; specialFacts is a curated supplement
// the teacher wants included for THIS poet across all of their poems.
model PoetAnnotation {
  slug         String   @id
  specialFacts String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Admin-attached videos for a poem. Appended to the static versions[]
// in lib/poems.ts when /admin/poems/[slug]/add-video saves a YouTube
// search result. Annotations (genre, themes, teacherNotes) still live
// in VideoAnnotation keyed by youtubeId, so a PoemVideo + a matching
// VideoAnnotation row work together exactly like a static + DB-override
// pair.
model PoemVideo {
  id        String   @id @default(cuid())
  poemSlug  String
  youtubeId String
  label     String?
  position  Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([poemSlug, youtubeId])
  @@index([poemSlug])
}

// One row per Anthropic API call. Written from lib/api-usage.ts after
// each generator's client.messages.create returns; never blocks the
// caller on failure. Powers the /admin/usage dashboard.
model ApiUsage {
  id                  String   @id @default(cuid())
  // One of: 'questions' | 'topics' | 'teacher-edition' | 'teacher-ask'
  // | 'single-question'. Stored as String so adding a new generator
  // doesn't need an enum migration.
  generator           String
  model               String
  inputTokens         Int
  outputTokens        Int
  cacheReadTokens     Int      @default(0)
  cacheCreationTokens Int      @default(0)
  // USD cost computed at write time from current model pricing. We
  // store the computed number (not just the tokens) so historical
  // reports stay correct even if Anthropic changes their prices.
  costUsd             Float
  poemSlug            String?
  audience            String?
  createdAt           DateTime @default(now())

  @@index([createdAt])
  @@index([generator, createdAt])
  @@index([poemSlug])
}

// Per-component model override. One row per generator. When no row
// exists, lib/model-config.ts returns the hardcoded default. Editable
// from the model picker on /admin/usage so we can drop cheap features
// to Sonnet/Haiku and keep the question generators on Opus.
model ModelSetting {
  // Component key: 'questions' | 'single-question' | 'topics' |
  // 'teacher-edition' | 'teacher-ask' | 'concierge'
  component String   @id
  model     String

  updatedAt DateTime @updatedAt
}

// Singleton row holding the OAuth refresh token for the qed'bop YouTube
// channel. The refresh token is long-lived; access tokens are derived
// from it on demand and cached in memory. Only the channel owner's
// consent populates this — it lets the admin list unlisted uploads,
// which an API key alone cannot see. id is always "singleton".
model YouTubeToken {
  id           String   @id @default("singleton")
  refreshToken String
  scope        String?
  channelId    String?
  connectedAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

